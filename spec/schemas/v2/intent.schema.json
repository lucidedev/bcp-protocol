{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bcp-protocol.org/schemas/v0.2/intent.json",
  "title": "BCP v0.2 INTENT",
  "type": "object",
  "required": ["bcp_version", "type", "sessionId", "timestamp", "service"],
  "additionalProperties": false,
  "properties": {
    "bcp_version": { "const": "0.2" },
    "type": { "const": "intent" },
    "sessionId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "service": { "type": "string", "minLength": 1 },
    "budget": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 1 },
    "auth": { "type": "string", "enum": ["none", "platform", "ed25519"] },
    "rfqId": { "type": "string", "minLength": 1 },
    "callbackUrl": { "type": "string", "format": "uri" },
    "signature": { "type": "string" }
  }
}
