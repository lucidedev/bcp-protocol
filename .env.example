# BCP Agent Identity — copy this to .env and fill in values
# Fund the EVM wallets with Base Sepolia ETH to use on-chain escrow.
# If keys are left blank, fresh keypairs are generated on first run.

# ── Buyer ───────────────────────────────────────────────────
BUYER_ORG_ID=acme-corp
BUYER_ED25519_PRIVATE_KEY=
BUYER_ED25519_PUBLIC_KEY=
BUYER_EVM_PRIVATE_KEY=

# ── Seller ──────────────────────────────────────────────────
SELLER_ORG_ID=widgets-inc
SELLER_ED25519_PRIVATE_KEY=
SELLER_ED25519_PUBLIC_KEY=
SELLER_EVM_PRIVATE_KEY=

# ── On-chain escrow ────────────────────────────────────────
# Deploy BCPEscrow.sol to Base Sepolia and paste the address here.
BCP_ESCROW_CONTRACT_ADDRESS=

# ── RPC ─────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Token (USDC on Base Sepolia) ────────────────────────────
USDC_TOKEN_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_DECIMALS=6
