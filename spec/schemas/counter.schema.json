{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BCP Counter Message",
  "type": "object",
  "required": ["bcp_version", "type", "sessionId", "timestamp", "counterPrice"],
  "properties": {
    "bcp_version": { "const": "0.3" },
    "type": { "const": "counter" },
    "sessionId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "counterPrice": { "type": "number", "minimum": 0 },
    "reason": { "type": "string" },
    "callbackUrl": { "type": "string", "format": "uri" },
    "signature": { "type": "string" },
    "did": { "type": "string" }
  },
  "additionalProperties": false
}
