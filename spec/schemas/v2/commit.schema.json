{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bcp-protocol.org/schemas/v0.2/commit.json",
  "title": "BCP v0.2 COMMIT",
  "type": "object",
  "required": ["bcp_version", "type", "sessionId", "timestamp", "agreedPrice", "currency"],
  "additionalProperties": false,
  "properties": {
    "bcp_version": { "const": "0.2" },
    "type": { "const": "commit" },
    "sessionId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "agreedPrice": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 1 },
    "settlement": { "type": "string", "enum": ["none", "invoice", "x402", "escrow"] },
    "escrow": {
      "type": "object",
      "required": ["contractAddress"],
      "additionalProperties": false,
      "properties": {
        "contractAddress": { "type": "string", "minLength": 1 },
        "txHash": { "type": "string" }
      }
    },
    "callbackUrl": { "type": "string", "format": "uri" },
    "signature": { "type": "string" }
  }
}
