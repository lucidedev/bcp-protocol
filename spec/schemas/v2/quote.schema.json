{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bcp-protocol.org/schemas/v0.2/quote.json",
  "title": "BCP v0.2 QUOTE",
  "type": "object",
  "required": ["bcp_version", "type", "sessionId", "timestamp", "price", "currency"],
  "additionalProperties": false,
  "properties": {
    "bcp_version": { "const": "0.2" },
    "type": { "const": "quote" },
    "sessionId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "price": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 1 },
    "deliverables": { "type": "array", "items": { "type": "string" } },
    "estimatedDays": { "type": "number", "minimum": 0 },
    "validUntil": { "type": "string", "format": "date-time" },
    "settlement": { "type": "string", "enum": ["none", "invoice", "x402", "escrow"] },
    "callbackUrl": { "type": "string", "format": "uri" },
    "signature": { "type": "string" }
  }
}
