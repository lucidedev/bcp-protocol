{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bcp-protocol.org/schemas/v0.2/fulfil.json",
  "title": "BCP v0.2 FULFIL",
  "type": "object",
  "required": ["bcp_version", "type", "sessionId", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "bcp_version": { "const": "0.2" },
    "type": { "const": "fulfil" },
    "sessionId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "deliverables": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "string" },
    "proofHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "invoiceUrl": { "type": "string", "format": "uri" },
    "callbackUrl": { "type": "string", "format": "uri" },
    "signature": { "type": "string" }
  }
}
