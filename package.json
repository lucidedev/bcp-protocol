{
  "name": "@bcp-protocol/sdk",
  "version": "0.1.0",
  "description": "Business Commerce Protocol — the open-source B2B agent commerce layer for x402. Negotiation, escrow, invoicing & disputes between AI agents.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/src/index.js"
    },
    "./buyer": {
      "types": "./dist/src/buyer.d.ts",
      "require": "./dist/src/buyer.js"
    },
    "./seller": {
      "types": "./dist/src/seller.d.ts",
      "require": "./dist/src/seller.js"
    },
    "./mcp": {
      "types": "./dist/src/mcp/server.d.ts",
      "require": "./dist/src/mcp/server.js"
    }
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "spec/",
    "contracts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "demo:live": "ts-node examples/demo-live.ts",
    "demo:sdk": "ts-node examples/demo-sdk.ts",
    "seller": "ts-node examples/seller-server.ts",
    "buyer": "ts-node examples/buyer-client.ts",
    "mcp": "ts-node src/mcp/server.ts",
    "test": "jest --config jest.config.js",
    "lint": "tsc --noEmit",
    "website:build": "cd website && npm run build && touch ../docs/.nojekyll"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lucidedev/bcp-protocol"
  },
  "homepage": "https://github.com/lucidedev/bcp-protocol#readme",
  "keywords": [
    "b2b",
    "commerce",
    "protocol",
    "x402",
    "ai-agents",
    "stablecoin",
    "escrow",
    "negotiation",
    "mcp",
    "agentic-commerce"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^2.0.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.0",
    "uuid": "^10.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
