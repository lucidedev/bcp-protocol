{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bcp-protocol.org/schemas/quote.schema.json",
  "title": "BCP QUOTE Message",
  "description": "Seller agent responds with a signed offer",
  "type": "object",
  "required": [
    "bcp_version",
    "message_type",
    "quote_id",
    "intent_id",
    "timestamp",
    "seller",
    "offer",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "bcp_version": {
      "type": "string",
      "const": "0.1"
    },
    "message_type": {
      "type": "string",
      "const": "QUOTE"
    },
    "quote_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v4 unique identifier for this quote"
    },
    "intent_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the INTENT this quote responds to"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "seller": {
      "type": "object",
      "required": ["org_id", "agent_wallet_address", "credential"],
      "additionalProperties": false,
      "properties": {
        "org_id": {
          "type": "string",
          "description": "Unique identifier for the seller organization"
        },
        "agent_wallet_address": {
          "type": "string",
          "description": "Seller agent's wallet address"
        },
        "credential": {
          "type": "string",
          "description": "Verifiable credential or public key for the seller agent"
        }
      }
    },
    "offer": {
      "type": "object",
      "required": ["price", "currency", "payment_terms", "delivery_date", "validity_until", "line_items"],
      "additionalProperties": false,
      "properties": {
        "price": {
          "type": "number",
          "minimum": 0,
          "description": "Total price for the offer"
        },
        "currency": {
          "type": "string",
          "description": "Currency code (e.g. USDC, USDT)"
        },
        "payment_terms": {
          "type": "string",
          "enum": ["immediate", "net15", "net30", "net45", "net60", "net90"],
          "description": "Payment terms for this offer"
        },
        "delivery_date": {
          "type": "string",
          "format": "date-time",
          "description": "Expected delivery date in ISO 8601"
        },
        "validity_until": {
          "type": "string",
          "format": "date-time",
          "description": "Quote valid until this timestamp"
        },
        "line_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["description", "qty", "unit_price", "unit"],
            "additionalProperties": false,
            "properties": {
              "description": {
                "type": "string"
              },
              "qty": {
                "type": "number",
                "minimum": 0
              },
              "unit_price": {
                "type": "number",
                "minimum": 0
              },
              "unit": {
                "type": "string"
              }
            }
          }
        },
        "early_pay_discount": {
          "type": "object",
          "required": ["discount_percent", "if_paid_within_days"],
          "additionalProperties": false,
          "properties": {
            "discount_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "if_paid_within_days": {
              "type": "integer",
              "minimum": 1
            }
          },
          "description": "Optional early payment discount"
        }
      }
    },
    "signature": {
      "type": "string",
      "description": "Ed25519 signature of the canonical JSON payload"
    }
  }
}
